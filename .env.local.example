# ══════════════════════════════════════════════════════════════
#  SETUP LOCAL : créer deux fichiers à partir de ces exemples
#
#  1. Copier en .env          → pour Prisma CLI (migrate, studio, seed)
#     Contient : DATABASE_URL uniquement
#
#  2. Copier en .env.local    → pour Next.js (runtime)
#     Contient : tout le reste (secrets, API keys)
#
#  Les deux fichiers sont ignorés par git (.gitignore: .env*)
# ══════════════════════════════════════════════════════════════

# ──── .env (Prisma CLI) ──────────────────────────────────────
# Dev (SQLite, fichier local) :
DATABASE_URL="file:./dev.db"
# Prod (PostgreSQL sur Neon/Supabase) :
# DATABASE_URL="postgresql://user:pass@host:5432/primerenov"

# ──── .env.local (Next.js runtime) ──────────────────────────

# URL publique du site (meta OG, sitemap, robots.txt)
NEXT_PUBLIC_URL=https://primerenov.fr

# Mot de passe de connexion au panneau admin (/admin/login)
ADMIN_PASSWORD=

# Clé secrète JWT — minimum 32 caractères aléatoires
# Générer avec : openssl rand -base64 32
SESSION_SECRET=

# ──── Emails (Resend) ────────────────────────────────────────
# Compte gratuit : https://resend.com (3 000 emails/mois offerts)
RESEND_API_KEY=
EMAIL_FROM=Prime Rénov <contact@primerenov.fr>
EMAIL_TO=contact@primerenov.fr

# ──── Stockage d'images (Cloudinary) ────────────────────────
# Requis sur Vercel (filesystem éphémère)
# Compte gratuit : https://cloudinary.com (25 Go offerts)
# Clés : Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
